{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "messages": {
      "general": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["timestamp"]
      }
    },
    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "voice_mics": {
      ".read": "auth != null",
      "$slot": {
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "voice_signals": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    },
    "uno_rooms": {
      "$rid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
